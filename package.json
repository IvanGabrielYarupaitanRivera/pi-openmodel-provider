{
  "name": "pi-openmodel-provider",
  "version": "0.2.17",
  "description": "pi custom provider for OpenModel.ai - Multi-model AI gateway",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "openmodel",
    "provider",
    "ai-gateway"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanGabrielYarupaitanRivera/pi-openmodel-provider.git"
  },
  "homepage": "https://github.com/IvanGabrielYarupaitanRivera/pi-openmodel-provider#readme",
  "files": [
    "index.ts",
    "src/",
    "src/stub.d.ts",
    "AGENTS.md",
    ".agents/",
    "media/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.5.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:models": "tsx tests/test-models.ts",
    "test:auth": "tsx tests/test-auth.ts",
    "test:pricing": "tsx tests/test-pricing.ts",
    "test:stability": "tsx tests/test-stability.ts",
    "test:edge": "tsx tests/test-edge-cases.ts",
    "test:cache": "tsx tests/test-cache.ts",
    "test": "tsx tests/test-models.ts && tsx tests/test-auth.ts && tsx tests/test-pricing.ts && tsx tests/test-stability.ts && tsx tests/test-edge-cases.ts && tsx tests/test-cache.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./.agents/skills"
    ],
    "image": "https://raw.githubusercontent.com/IvanGabrielYarupaitanRivera/pi-openmodel-provider/master/media/thumbnail.jpeg",
    "video": "https://youtu.be/aUaXznGVuzg"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  }
}
